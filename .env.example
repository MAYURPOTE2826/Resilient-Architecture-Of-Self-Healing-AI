# ──────────────────────────────────────────────────────────────
# Self-Healing Engine — Environment Configuration Template
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
APP_ENV=production          # development | staging | production
DEBUG=false
HOST=0.0.0.0
PORT=5000

# ── Security (REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CHANGE_ME_generate_a_64_char_random_hex_secret
JWT_SECRET=CHANGE_ME_generate_a_64_char_random_hex_for_jwt
ADMIN_API_KEY=CHANGE_ME_generate_a_strong_random_api_key

# ── Admin Login Credentials (UI access) ───────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# JWT Expiry
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_MINUTES=10080   # 7 days

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── Database ──────────────────────────────────────────────────
# Leave blank to use SQLite (development only)
# Production: postgres://user:password@host:5432/db_name
DATABASE_URL=

# Directory where SQLite DB and ML artifacts are stored
DATA_DIR=/app/data

# ── Alerting (Email via SMTP) ─────────────────────────────────
SENDER_EMAIL=your_gmail_address@gmail.com
SENDER_PASSWORD=your_gmail_app_password_here
ADMIN_EMAIL=admin_recipient@gmail.com

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json             # json | console

# ── OpenTelemetry (OTLP Exporter) ────────────────────────────
# Set if using Jaeger, Datadog, or any OTLP-compatible collector
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Grafana (only used in docker-compose.prod.yml) ───────────
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_strong_grafana_password
